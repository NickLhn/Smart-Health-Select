# 根目录 docker-compose 环境变量示例
# 复制为 .env 后再填写真实值，然后再启动 docker compose。

MYSQL_ROOT_PASSWORD=replace_me
MYSQL_DATABASE=zhijian_db

SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace_me
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

ZHIJIAN_JWT_SECRET=replace_with_a_32_plus_char_secret
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com

ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_ACCESS_KEY_ID=
ALIYUN_OCR_ACCESS_KEY_SECRET=
ALIYUN_OCR_CONFIDENCE_THRESHOLD=0.8

LANGGRAPH_MYSQL_HOST=mysql
LANGGRAPH_MYSQL_PORT=3306
LANGGRAPH_MYSQL_USER=root
LANGGRAPH_MYSQL_PASSWORD=replace_me
LANGGRAPH_MYSQL_DB=zhijian_db
LANGGRAPH_BACKEND_BASE_URL=http://backend:8080/api
LANGGRAPH_TOOLS_BASE_URL=http://ai-tools:18080
LANGGRAPH_REDIS_HOST=redis
LANGGRAPH_REDIS_PORT=6379
LANGGRAPH_REDIS_DB=0
LANGGRAPH_REDIS_PASSWORD=
