FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

RUN pip install --no-cache-dir -i "${PIP_INDEX_URL}" -U pip

COPY zhijian_langgraph/requirements.txt .
RUN pip install --no-cache-dir -i "${PIP_INDEX_URL}" -r requirements.txt

COPY zhijian_langgraph/agent/ ./agent/
COPY zhijian_langgraph/tools_service/ ./tools_service/

EXPOSE 18081

CMD ["python", "-m", "uvicorn", "agent.app:app", "--host", "0.0.0.0", "--port", "18081"]
